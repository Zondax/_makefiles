# Print bake configuration
docker-bake-print: ## Print bake configuration
ifeq ($(HAS_BAKE_FILE),NO)
	@echo "❌ Error: $(DOCKER_BAKE_FILE) not found"
	@exit 1
else
	@$(MAKE) docker-bake-build DOCKER_BAKE_PRINT=1
endif

# List available bake targets
docker-bake-targets: ## List available bake targets
ifeq ($(HAS_BAKE_FILE),NO)
	@echo "❌ Error: $(DOCKER_BAKE_FILE) not found"
	@exit 1
else
	@echo "📑 Available bake targets:"
	@docker buildx bake -f $(DOCKER_BAKE_FILE) --print 2>/dev/null | \
		jq -r '.target | keys[]' | sort | sed 's/^/  - /' || \
		echo "Error: Unable to parse bake file"
endif

# List available bake groups
